FROM python:3.12-slim AS base

WORKDIR /app

FROM base AS deps
COPY pyproject.toml .
RUN pip install --no-cache-dir --upgrade pip setuptools && \
    pip install --no-cache-dir .

FROM deps AS app
COPY backend/ backend/
COPY alembic/ alembic/
COPY alembic.ini .
COPY scripts/ scripts/

EXPOSE 8000
CMD ["sh", "-c", "for i in 1 2 3 4 5; do alembic upgrade head && break; echo \"DB not ready, retry $i/5...\"; sleep 5; done || true; exec uvicorn backend.main:app --host 0.0.0.0 --port 8000"]
